# PostgreSQL
POSTGRES_DB=dirascan
POSTGRES_USER=dirascan
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://dirascan:change_me_in_production@db:5432/dirascan

# API
API_SECRET_KEY=change_me_in_production
CORS_ORIGINS=http://localhost:3000

# Mapbox (frontend — must be a public token starting with pk.)
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Facebook credentials (for facebook-scraper library)
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# Scraper behavior
PLAYWRIGHT_HEADLESS=true
SCRAPER_REQUEST_DELAY_SECONDS=2.0
# Persistent browser profile dir — mount a Docker volume here so cookies
# survive container restarts (makes the scraper look like a returning user).
COOKIES_DIR=/tmp/dirascan_cookies
